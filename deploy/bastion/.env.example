# Copie para .env: cp .env.example .env
# Ou gere a partir do netops-cli: ./install-from-netops-cli.sh

CONNECTOR_NAME=4WNET_BVA
CONNECTOR_TOKEN=

# URL do NetOps Server (sem barra final). Ex.: https://4wnet.devops.k3gsolutions.com.br
NETOPS_SERVER_URL=http://127.0.0.1:8085

HEARTBEAT_INTERVAL=60
JOB_POLL_INTERVAL=10
JOB_TIMEOUT=120

# WireGuard gerenciado pelo netops-cli — agent só executa jobs na LAN/L2TP
WG_ENABLED=false
WG_INTERFACE=netops
WG_CONFIG_PATH=/etc/wireguard/netops.conf

LAN_INTERFACE=eth0
WAN_INTERFACE=enp5s0

SSH_CONNECT_TIMEOUT=15
SSH_COMMAND_TIMEOUT=90

SNMP_TIMEOUT=5
SNMP_RETRIES=1
SNMP_MAX_LINES=500

LOG_LEVEL=INFO
LOG_DIR=/var/log/netops-connector
STATE_DIR=/var/run/netops-connector
AGENT_VERSION=1.1.0
